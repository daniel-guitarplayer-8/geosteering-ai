{
  "mcpServers": {
    "consensus": {
      "command": "python",
      "args": ["tools/consensus-mcp-server/server.py"],
      "env": {
        "S2_API_KEY": "${S2_API_KEY}"
      }
    },
    "colab-mcp": {
      "command": "uvx",
      "args": ["git+https://github.com/googlecolab/colab-mcp"],
      "timeout": 60000
    }
  }
}