        </item>
        <item row="0" column="1">
         <widget class="QSpinBox" name="workersSpin">
          <property name="minimum"><number>1</number></property>
          <property name="maximum"><number>256</number></property>
          <property name="value"><number>16</number></property>
          <property name="toolTip"><string>Workers sandbox (estado/UI; ProcessPool real = Fatia 5).</string></property>
         </widget>
        </item>
        <item row="1" column="0">
         <widget class="QLabel" name="threadsLabel">
          <property name="text"><string>Nº de threads por worker:</string></property>
         </widget>
        </item>
        <item row="1" column="1">
         <widget class="QSpinBox" name="threadsSpin">
          <property name="minimum"><number>1</number></property>
          <property name="maximum"><number>256</number></property>
          <property name="value"><number>2</number></property>
          <property name="toolTip"><string>Threads/worker — efeito real via numba.set_num_threads.</string></property>
         </widget>
        </item>
        <item row="2" column="0" colspan="2">
         <widget class="QLabel" name="cpuInfoLabel">
          <property name="text"><string>CPU: — cores físicos · — threads lógicas</string></property>
         </widget>
        </item>
        <item row="3" column="0" colspan="2">
         <widget class="QLabel" name="parallelWarnLabel">
          <property name="wordWrap"><bool>true</bool></property>
          <property name="text"><string/></property>
         </widget>
        </item>
       </layout>
      </widget>
     </item>
     <item>
      <widget class="QGroupBox" name="executionBox">
       <property name="title">
        <string>Execução (Fatia 6a)</string>
       </property>
       <layout class="QVBoxLayout" name="executionLayout">
        <item>
         <layout class="QHBoxLayout" name="execButtonsLayout">
          <item>
           <widget class="QPushButton" name="runButton">
            <property name="text"><string>Run</string></property>
           </widget>
          </item>
          <item>
           <widget class="QPushButton" name="pauseButton">
            <property name="text"><string>Pausar</string></property>
            <property name="enabled"><bool>false</bool></property>
           </widget>
          </item>
          <item>
           <widget class="QPushButton" name="resumeButton">
            <property name="text"><string>Retomar</string></property>
            <property name="enabled"><bool>false</bool></property>
           </widget>
          </item>
          <item>
           <widget class="QPushButton" name="cancelButton">
            <property name="text"><string>Cancelar</string></property>
            <property name="enabled"><bool>false</bool></property>
           </widget>
          </item>
         </layout>
        </item>
        <item>
         <layout class="QHBoxLayout" name="sessionButtonsLayout">
          <item>
           <widget class="QPushButton" name="saveButton">
            <property name="text"><string>Salvar sessão…</string></property>
           </widget>
          </item>
          <item>
           <widget class="QPushButton" name="openButton">
            <property name="text"><string>Abrir sessão…</string></property>
           </widget>
          </item>
          <item>
           <widget class="QLabel" name="statusLabel">
            <property name="text"><string>idle</string></property>
           </widget>
          </item>
          <item>
           <spacer name="statusSpacer">
            <property name="orientation"><enum>Qt::Horizontal</enum></property>
            <property name="sizeHint" stdset="0">
             <size><width>40</width><height>20</height></size>
            </property>
           </spacer>
          </item>
         </layout>
        </item>
        <item>
         <widget class="QProgressBar" name="progressBar">
          <property name="value"><number>0</number></property>
         </widget>
        </item>
        <item>
         <layout class="QHBoxLayout" name="outputLayout">
          <item>
           <widget class="QLabel" name="outputDirLabel">
            <property name="text"><string>Saída:</string></property>
           </widget>
          </item>
          <item>
           <widget class="QLineEdit" name="outputDirEdit">
            <property name="placeholderText"><string>Diretório de saída (.dat/.out)</string></property>
           </widget>
          </item>
          <item>
           <widget class="QPushButton" name="browseOutButton">
            <property name="text"><string>…</string></property>
            <property name="maximumWidth"><number>32</number></property>
           </widget>
          </item>
         </layout>
        </item>
        <item>
         <widget class="QCheckBox" name="saveArtifactsCheck">
          <property name="text"><string>Salvar artefatos Fortran-compat (.dat binário 22-col + .out ASCII)</string></property>
         </widget>
        </item>
       </layout>
      </widget>
     </item>
     <item>
      <widget class="QGroupBox" name="logBox">
       <property name="title">
        <string>Log (Fatia 6a)</string>
       </property>
       <layout class="QVBoxLayout" name="logLayout">
        <item>
         <widget class="QPlainTextEdit" name="logEdit">
          <property name="readOnly"><bool>true</bool></property>
          <property name="placeholderText"><string>Log da simulação…</string></property>
         </widget>
        </item>
       </layout>
      </widget>
     </item>
     <item>
      <widget class="QGroupBox" name="historyBox">
       <property name="title">
        <string>Experimentos e histórico (design-alvo · Fatia 6c)</string>
       </property>
       <layout class="QVBoxLayout" name="historyLayout">
        <item>
         <layout class="QHBoxLayout" name="experimentButtonsLayout">
          <item>
           <widget class="QPushButton" name="expNewButton">
            <property name="text"><string>Novo</string></property>
            <property name="toolTip"><string>Cria um novo experimento (.exp.json).</string></property>
           </widget>
          </item>
          <item>
           <widget class="QPushButton" name="expOpenButton">
            <property name="text"><string>Abrir</string></property>
            <property name="toolTip"><string>Abre um experimento salvo.</string></property>
           </widget>
          </item>
          <item>
           <widget class="QPushButton" name="expSaveButton">
            <property name="text"><string>Salvar</string></property>
            <property name="toolTip"><string>Salva o experimento atual (snapshots + params).</string></property>
           </widget>
          </item>
          <item>
           <widget class="QPushButton" name="expCloseButton">
            <property name="text"><string>Fechar</string></property>
            <property name="toolTip"><string>Fecha o experimento atual.</string></property>
           </widget>
          </item>
         </layout>
        </item>
        <item>
         <widget class="QLineEdit" name="historySearchEdit">
          <property name="placeholderText"><string>Filtrar histórico…</string></property>
         </widget>
        </item>
        <item>
         <widget class="QListWidget" name="historyList"/>
        </item>
        <item>
         <widget class="QPushButton" name="expClearButton">
          <property name="text"><string>Limpar histórico</string></property>
          <property name="toolTip"><string>Remove todos os snapshots do experimento (pede confirmação).</string></property>
         </widget>
        </item>
       </layout>
      </widget>
     </item>
     <item>
      <widget class="QGroupBox" name="resultsBox">
       <property name="title">
        <string>Galeria de resultados (design-alvo · Fatia 6d)</string>
       </property>
       <layout class="QVBoxLayout" name="resultsLayout">
        <item>
         <layout class="QHBoxLayout" name="galleryControlsLayout">
          <item>
           <widget class="QLabel" name="plotBackendLabel">
            <property name="text"><string>Plot:</string></property>
           </widget>
          </item>
          <item>
           <widget class="QComboBox" name="plotBackendCombo">
            <property name="toolTip"><string>Motor de plotagem: PyQtGraph (interativo, default) ou matplotlib (publicação).</string></property>
            <item><property name="text"><string>pyqtgraph</string></property></item>
            <item><property name="text"><string>matplotlib</string></property></item>
           </widget>
          </item>
          <item>
           <widget class="QLabel" name="plotModeLabel">
            <property name="text"><string>Modo:</string></property>
           </widget>
          </item>
          <item>
           <widget class="QComboBox" name="plotModeCombo">
            <property name="toolTip"><string>O que plotar: curvas, perfil ρ, anisotropia λ ou heatmap do ensemble.</string></property>
            <item><property name="text"><string>Curvas</string></property></item>
            <item><property name="text"><string>Perfil ρ</string></property></item>
            <item><property name="text"><string>Anisotropia λ</string></property></item>
            <item><property name="text"><string>Heatmap ensemble</string></property></item>
           </widget>
          </item>
         </layout>
        </item>
        <item>
         <layout class="QHBoxLayout" name="channelControlsLayout">
          <item>
           <widget class="QLabel" name="channelLabel">
            <property name="text"><string>Canal:</string></property>
           </widget>
          </item>
          <item>
           <widget class="QComboBox" name="channelCombo">
            <property name="toolTip"><string>Canal: componente do tensor H (Hxx..Hzz) ou geosinal (USD/UAD/UHR/UHA/U3DF).</string></property>
            <item><property name="text"><string>Hxx</string></property></item>
            <item><property name="text"><string>Hzz</string></property></item>
            <item><property name="text"><string>USD</string></property></item>
            <item><property name="text"><string>U3DF</string></property></item>
           </widget>
          </item>
          <item>
           <widget class="QComboBox" name="plotKindCombo">
            <property name="toolTip"><string>Transform: Re / Im / |H| / fase.</string></property>
            <item><property name="text"><string>Re</string></property></item>
            <item><property name="text"><string>Im</string></property></item>
            <item><property name="text"><string>|H|</string></property></item>
            <item><property name="text"><string>Fase (°)</string></property></item>
           </widget>
          </item>
         </layout>
        </item>
        <item>
         <layout class="QHBoxLayout" name="animationLayout">
          <item>
           <widget class="QPushButton" name="animPlayButton">
            <property name="text"><string>▶</string></property>
            <property name="checkable"><bool>true</bool></property>
            <property name="maximumSize"><size><width>40</width><height>16777215</height></size></property>
            <property name="toolTip"><string>Play/Pause — varre os modelos do ensemble (single-model playback).</string></property>
           </widget>
          </item>
          <item>
           <widget class="QSlider" name="animSlider">
            <property name="orientation"><enum>Qt::Horizontal</enum></property>
            <property name="toolTip"><string>Modelo em foco da animação.</string></property>
           </widget>
          </item>
          <item>
           <widget class="QComboBox" name="animSpeedCombo">
            <property name="toolTip"><string>Velocidade do playback (frames por segundo).</string></property>
            <item><property name="text"><string>1 fps</string></property></item>
            <item><property name="text"><string>5 fps</string></property></item>
            <item><property name="text"><string>10 fps</string></property></item>
            <item><property name="text"><string>20 fps</string></property></item>
           </widget>
          </item>
         </layout>
        </item>
       </layout>
      </widget>
     </item>
    </layout>
   </item>
  </layout>
 </widget>
