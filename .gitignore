# ══════════════════════════════════════════════════════════════════════════════
# Geosteering AI — .gitignore
# ══════════════════════════════════════════════════════════════════════════════

# ── Dados binarios (grandes, ficam no Google Drive) ──────────────────────────
*.dat
*.out
*.bin

# ── Modelos treinados ────────────────────────────────────────────────────────
*.keras
*.h5
*.pb
*.tflite
saved_model/
checkpoints/
experiments/

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# ── Ambientes virtuais ──────────────────────────────────────────────────────
.venv/
venv/
env/

# ── IDE ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ── Jupyter / Colab ──────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Credenciais ──────────────────────────────────────────────────────────────
.env
*.key
credentials.json

# ── Plots e saidas temporarias ───────────────────────────────────────────────
Plotagens/
*.png
*.jpg
*.pdf
!docs/**/*.png
!docs/**/*.pdf

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Dados grandes no Drive ───────────────────────────────────────────────────
Fortran_Gerador/*.dat
Fortran_Gerador/*.out

# ── Pacotes de Skill legados ─────────────────────────────────────────────────
*.skill
.claude/worktrees/

# ── Dados de usuário do Simulation Manager (não versionados) ─────────────────
sm_experiments/*.exp.json
sm_heartbeat.log
benchmarks/reports/

# ── Tooling local (harness Claude Code) ──────────────────────────────────────
.agents/

# ── Etapa 0 / 1 — Quality Mesh & Multi-Agent Hardening ───────────────────────
# Backups locais (preservados via .claude/hooks/backup-pre-edit.sh)
.backups/
# Lock-files de agentes paralelos (efêmeros, gerenciados por LockManager)
.claude/locks/
# Estado runtime do orquestrador (registro de agentes ativos)
.claude/active_agents.json
.claude/state.json
# File-watcher daemon log (Quality Mesh L7)
.claude/watcher.log
# Telemetria CSV histórica (sumário em CHANGELOG; CSVs locais)
.claude/telemetry/*.csv

# ── Relatórios e backups grandes (não versionar) ─────────────────────────────
Resultados_Relatorio_2026/
old_geosteering_ai/
latex-document-skill-main.zip
# Pastas locais de prompts e relatórios LaTeX (não versionar)
Prompts_Geosteering_AI/
Relatorio_2025/
Relatorio_2026/
# Backups manuais de relatórios em docs/reports/
docs/reports/BACKUP*.md
